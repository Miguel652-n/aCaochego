# ========================
# Database Configuration
# ========================
# For production use PostgreSQL
# DATABASE_URL=postgresql://user:password@localhost:5432/acaochego
# For development use SQLite (default if not set)
# DATABASE_URL=sqlite:///./local.db

# ========================
# Anthropic API Configuration
# ========================
# Get your API key from: https://console.anthropic.com/
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# ========================
# CORS Configuration
# ========================
# Comma-separated list of allowed origins
# ALLOWED_ORIGINS=http://localhost:3000,https://acaochego.com
ALLOWED_ORIGINS=*

# ========================
# Admin Credentials
# ========================
# Note: Change these credentials in admin.js for production!
# ADMIN_USER=admin
# ADMIN_PASSWORD=acaochego2025
